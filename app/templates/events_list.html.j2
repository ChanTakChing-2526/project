{% extends "base.html.j2" %}
{% block app_content %}
<h1>近期活動</h1>
<div class="row">
    {% for event in events %}
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5>{{ event.title }}</h5>
                <p>{{ event.description[:100] }}...</p>
                <a href="{{ url_for('event_detail', event_id=event.id) }}" class="btn btn-primary">
                    睇活動電影
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endblock %}