<form method="POST">
    {{ form.hidden_tag() }}
    {{ form.selected_seats(id="selected_seats_input") }}

    <div class="seat-grid">
        {% for seat in all_seats %}
            {% if seat.id in booked_seat_ids %}
                <div class="seat booked">{{ seat.row_code }}{{ seat.seat_number }}</div>
            {% else %}
                <div class="seat" data-id="{{ seat.id }}" onclick="toggleSeat(this)">
                    {{ seat.row_code }}{{ seat.seat_number }}
                </div>
            {% endif %}
        {% endfor %}
    </div>

    <div style="margin-top: 30px;">
        {{ form.submit(class="btn btn-primary") }}
    </div>
</form>

<script>
    let selectedSeats = [];
    function toggleSeat(element) {
        const seatId = element.getAttribute('data-id');
        if (element.classList.contains('selected')) {
            element.classList.remove('selected');
            selectedSeats = selectedSeats.filter(id => id !== seatId);
        } else {
            element.classList.add('selected');
            selectedSeats.push(seatId);
        }
        // 更新隱藏欄位值
        document.getElementById('selected_seats_input').value = selectedSeats.join(',');
    }
</script>

{% endblock %}