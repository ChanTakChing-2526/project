{% extends "base.html.j2" %}
{% block title %}{{ page_title or "Ticketing" }}{% endblock %}
{% block content %}
    <div class="container mt-4">
        <h2 class="mb-4">{{ page_title or "Now showing" }}</h2>
        <div class="row">
            {% for movie in movies %}
                <div class="col-12 mb-4">
                    <div class="card shadow-sm">
                        <div class="row g-0">
                            <div class="col-md-3">
                                <img src="{{ movie.poster_url }}"
                                     alt="{{ movie.moviename }}"
                                     class="poster-img">
                            </div>
                            <div class="col-md-5">
                                <div class="card-body">
                                    <h4 class="card-title">{{ movie.moviename }}</h4>
                                    <p class="text-muted">{{ movie.runtime }} minutes | {{ movie.category }} | {{ movie.language }}</p>
                                    <div class="mb-3">
                                        {% for fmt in movie.formats %}<span class="badge bg-primary me-1">{{ fmt }}</span>{% endfor %}
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 border-start">
                                <div class="card-body">
                                    <h6 class="text-muted mb-3">Available screenings</h6>
                                    {% if movie.showtimes %}
                                        {% for show in movie.showtimes[:5] %}
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div>
                                                    <strong>{{ show.start_time.strftime("%H:%M") }}</strong>
                                                    <br>
                                                    <small class="text-muted">{{ show.cinema.cinemaname }} • {{ show.hall.hallname }}</small>
                                                </div>
                                                <a href="{{ url_for('ticket_select', showtime_id=show.id) }}"
                                                   class="btn btn-sm btn-danger">Select</a>
                                            </div>
                                        {% endfor %}
                                    {% else %}
                                        <p class="text-muted small">No matches available.</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    <style>
    .poster-img {
        width: 100%;
        height: 400px;
        object-fit: cover;
    }
    </style>
    {{ super() }}
{% endblock %}
