{% extends "base.html.j2" %}

{% block app_content %}
<div class="container mt-4">
    <h1 class="mb-4">{{ page_title }}</h1>

    {% if current_filter %}
    <p class="text-muted mb-4">目前篩選：{{ current_filter }}</p>
    {% endif %}

    {% for movie in movies %}
    <div class="card mb-4 shadow-sm">
        <div class="row g-0">
            <!-- 左邊海報 -->
            <div class="col-md-3">
                {% if movie.poster_url %}
                <img src="{{ movie.poster_url }}" class="img-fluid h-100" 
                     alt="{{ movie.moviename }}" style="object-fit: cover; height: 240px;">
                {% endif %}
            </div>

            <!-- 中間電影資訊 -->
            <div class="col-md-5">
                <div class="card-body">
                    <h4 class="card-title">{{ movie.moviename }}</h4>
                    <p class="text-muted">
                        {{ movie.runtime }} 分鐘 ・ {{ movie.language }} ・ {{ movie.category }}
                    </p>
                    
                    {% if movie.formats %}
                    <div class="mb-3">
                        {% for fmt in movie.formats %}
                            <span class="badge bg-danger me-1">{{ fmt }}</span>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <a href="#" class="btn btn-outline-primary btn-sm">查看預告</a>
                </div>
            </div>

            <!-- 右邊場次列表 -->
            <div class="col-md-4 border-start">
                <div class="card-body">
                    <h6 class="text-primary mb-3">場次時間</h6>
                    
                    {% if movie.showtimes %}
                        {% for show in movie.showtimes[:4] %}   <!-- 最多顯示 4 個場次 -->
                        <div class="d-flex justify-content-between align-items-center mb-3 py-1 border-bottom">
                            <div>
                                <strong>{{ show.start_time.strftime('%H:%M') }}</strong><br>
                                <small class="text-muted">{{ show.format_type or "標準" }}</small>
                            </div>
                            <div class="text-end">
                                <small class="text-muted">影廳 {{ show.hall.hallname if show.hall else '-' }}</small><br>
                                <span class="fw-bold text-danger">${{ show.price_base }}</span>
                            </div>
                            <a href="#" class="btn btn-sm btn-danger">選座</a>
                        </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted small">暫無場次</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endfor %}

    {% if not movies %}
    <div class="alert alert-info text-center py-5">
        暫時沒有符合條件的電影。
    </div>
    {% endif %}
</div>
{% endblock %}