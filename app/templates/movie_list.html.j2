{% extends "base.html.j2" %}

{% block title %}{{ page_title or "Ticketing" }}{% endblock %}

{% block content %}
<nav class="navbar navbar-default" style="border: none; margin-bottom: 0;">
        <div class="container-fluid"> <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
                <ul class="nav navbar-nav navbar-center" style="display: flex; justify-content: center; float: none;">
                    <li><a href="/ticketing">Ticketing</a></li>
                    <li><a href="/upcoming">Upcoming</a></li>
                    <li><a href="/events">Special</a></li>
                    <li><a href="/cinema">Cinema</a></li>
                    <li><a href="#">Gift Card Shop</a></li>
                </ul>
            </div>
        </div>
        <div style="height: 2px; background-color: red; width: 100%;"></div>
</nav>
<div class="container mt-4">
    <h2 class="mb-4">{{ page_title or "現正上映" }}</h2>

    <div class="row">
        {% for movie in movies %}
        <div class="col-12 mb-4">
            <div class="card shadow-sm">
                <div class="row g-0">
                    <!-- 左邊海報 -->
                    <div class="col-md-3">
                        <img src="{{ movie.poster_url }}" class="img-fluid h-100" style="object-fit: cover;" alt="{{ movie.moviename }}">
                    </div>

                    <!-- 中間電影資訊 -->
                    <div class="col-md-5">
                        <div class="card-body">
                            <h4 class="card-title">{{ movie.moviename }}</h4>
                            <p class="text-muted">
                                {{ movie.runtime }} 分鐘 | {{ movie.category }} | {{ movie.language }}
                            </p>

                            <div class="mb-3">
                                {% for fmt in movie.formats %}
                                <span class="badge bg-primary me-1">{{ fmt }}</span>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <!-- 右邊：場次列表 -->
                    <div class="col-md-4 border-start">
                        <div class="card-body">
                            <h6 class="text-muted mb-3">可觀看場次</h6>
                            {% if movie.showtimes %}
                                {% for show in movie.showtimes[:5] %}   <!-- 最多顯示5個場次 -->
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div>
                                        <strong>{{ show.start_time.strftime('%H:%M') }}</strong><br>
                                        <small class="text-muted">{{ show.cinema.cinemaname }} • {{ show.hall.hallname }}</small>
                                    </div>
                                    <a href="{{ url_for('ticket_select', showtime_id=show.id) }}" 
                                       class="btn btn-sm btn-danger">選座</a>
                                </div>
                                {% endfor %}
                            {% else %}
                                <p class="text-muted small">暫無場次</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}