{% block app_content %}
<nav class="navbar navbar-default" style="border: none; margin-bottom: 0;">
        <div class="container-fluid"> <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
                <ul class="nav navbar-nav navbar-center" style="display: flex; justify-content: center; float: none;">
                    <li><a href="#">Ticketing</a></li>
                    <li><a href="#">Upcoming</a></li>
                    <li><a href="#">Special</a></li>
                    <li><a href="#">Cinema</a></li>
                    <li><a href="#">Gift Card Shop</a></li>
                </ul>
            </div>
        </div>
        <div style="height: 2px; background-color: red; width: 100%;"></div>
    </nav>
<style>
    body { background-color: #fff; }
    .container { width: 100% !important; max-width: 100% !important; padding: 0 !important; }
    
    .cinema-image {
        width: 100%;
        height: 100vh;
        object-fit: cover;
        display: block;
    }

    .login-form-container {
        padding: 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100vh;
    }

    .form-title {
        font-size: 20px;
        color: #333;
        margin-bottom: 20px;
        position: relative;
        padding-left: 15px;
    }
    .form-title::before {
        content: '';
        position: absolute;
        left: 0;
        top: 3px;
        height: 18px;
        width: 3px;
        background-color: red;
    }

    .form-control-custom {
        border-radius: 0; 
        border: 1px solid #ccc;
        height: 40px;
        margin-bottom: 15px;
        font-size: 14px;
    }

    .btn-custom-login {
        background-color: #555;
        color: #fff;
        border-radius: 0;
        width: 100%;
        height: 45px;
        border: none;
        font-weight: bold;
        margin-top: 10px;
    }
    .btn-custom-register {
        background-color: #ed4e51;
        color: #fff;
        border-radius: 0;
        width: 100%;
        height: 45px;
        border: none;
        font-weight: bold;
        margin-top: 20px;
    }

    .link-forget {
        color: red;
        text-align: center;
        display: block;
        margin-bottom: 15px;
    }

    .or-divider {
        text-align: center;
        margin-top: 20px;
        position: relative;
        color: #999;
    }
    .or-divider::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        width: 45%;
        height: 1px;
        border-top: 1px dashed #ccc;
    }
    .or-divider::after {
        content: '';
        position: absolute;
        right: 0;
        top: 50%;
        width: 45%;
        height: 1px;
        border-top: 1px dashed #ccc;
    }
</style>

<div class="row" style="margin: 0;">
    <div class="col-md-7" style="padding: 0;">
        <img src="https://www.cinema.com.hk/images/bw_login_img.jpg" alt="Cinema" class="cinema-image">
    </div>

    <div class="col-md-5" style="padding: 0;">
        <div class="login-form-container">
            <h2 class="form-title">Member Login</h2>
            
            <form action="" method="post">
                {{ form.hidden_tag() }}
                
                {{ form.username(class="form-control form-control-custom", placeholder="Username / Member ID / Email") }}
                
                {{ form.password(class="form-control form-control-custom", placeholder="Password") }}
                
                <div class="checkbox" style="margin-top: -5px; font-size: 13px;">
                    <label>
                        {{ form.remember_me() }} Remember Me
                    </label>
                </div>

                <a href="{{ url_for('register') }}" class="link-forget">Forget Password?</a>

                {{ form.submit(class="btn btn-custom-login", value="Login") }}

                <div class="or-divider">Or</div>

                <a href="{{ url_for('register') }}" class="btn btn-custom-register">Register</a>
            </form>
        </div>
    </div>
</div>
{% endblock %}