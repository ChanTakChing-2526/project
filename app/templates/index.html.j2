{% extends "base.html.j2" %}

{% block app_content %}
<style>
    body { background-color: #ffffff !important; margin: 0; }
    
    .hero-black-section { 
        background-color: #000; 
        padding: 30px 0; 
    }

    .carousel-inner, .carousel-inner .item img {
        height: 320px !important; 
        width: 100%;
        object-fit: cover;
    }

    .carousel-control {
        width: 5%;
        background-image: none !important;
    }

    .special-list {
        display: flex;
        flex-direction: column;
        height: 320px; 
        justify-content: space-between;
        padding-left: 20px;
    }
    
    .special-item {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 380px;
        text-decoration: none;
    }

    .special-item img {
        width: 380px;
        height: 125px;
        object-fit: cover;
        border: 1px solid #333;
        transition: opacity 0.3s;
    }

    .special-item img:hover { opacity: 0.8; }

    .gold-label-fixed {
        color: #f4d150;
        font-weight: bold;
        font-size: 18px;
        margin-top: 8px;
        display: block;
        width: 380px;
    }

    .banner-title-style {
        color: #f4d150;
        font-weight: bold;
        font-size: 22px;
        margin-top: 15px;
        text-align: center;
        min-height: 35px;
    }

    .red-divider { height: 5px; background-color: #e60012; }
    
    .movie-link img {
        transition: transform 0.3s;
        width: 100%; 
        border: 1px solid #eee;
    }
    
    .movie-link img:hover { transform: scale(1.02); }

    .sub-category-nav {
        display: flex;
        justify-content: center;
        list-style: none;
        padding: 20px 0;
        border-bottom: 1px solid #eee;
        margin-bottom: 30px;
    }
    .sub-category-nav li {
        padding: 0 25px;
        border-right: 1px solid #ddd;
    }
    .sub-category-nav li:last-child { border-right: none; }
    .sub-category-nav a {
        color: #000;
        font-weight: bold;
        font-size: 18px;
        text-decoration: none;
        cursor: pointer;
    }
    .sub-category-nav a:hover { color: #e60012; }

    .cinema-video {
    height: 400px;
    object-fit: cover;
    }
</style>

<div class="hero-black-section">
    <div class="container">
        <div class="row" style="display: flex; align-items: flex-start; justify-content: center;">
            <div class="col-md-7">
                <div id="balancedCarousel" class="carousel slide" data-ride="carousel" data-interval="3000">
                    <div class="carousel-inner">
                        <div class="item active" data-title="寒戰 1994">
                            <a href="/movies/"><video class="w-100 rounded cinema-video" controls autoplay muted>
                                <source src="https://trailer.cinema.com.hk/trailer/2026-05-01ColdWar1994_Trailer02_Online.mp4" type="video/mp4">
                                    Your browser does not support the video tag.</video></a>
                        </div>
                        <div class="item" data-title="穿PRADA的惡魔2">
                            <a href="/movies/"><video class="w-100 rounded cinema-video" controls autoplay muted>
                                <source src="https://trailer.cinema.com.hk/trailer/2026-04-29TheDevilWearsPrada2_TrailerB.mp4" type="video/mp4">
                                    Your browser does not support the video tag.</video></a>
                        </div>
                        <div class="item" data-title="《夜王》（導演版）">
                            <a href="/movies/"><video class="w-100 rounded cinema-video" controls autoplay muted>
                                <source src="https://trailer.cinema.com.hk/trailer/2026-04-16NightKing.mp4" type="video/mp4">
                                    Your browser does not support the video tag.</video></a>
                        </div>
                    </div>
                    
                    <a class="left carousel-control" href="#balancedCarousel" data-slide="prev">
                        <span class="glyphicon glyphicon-chevron-left"></span>
                    </a>
                    <a class="right carousel-control" href="#balancedCarousel" data-slide="next">
                        <span class="glyphicon glyphicon-chevron-right"></span>
                    </a>
                </div>
                <div id="banner-text" class="banner-title-style"></div>
            </div>

            <div class="col-md-5">
                <div class="special-list">
                    <a href="/events" class="special-item">
                        <img src="{{ url_for('static', filename='1015-300x400.jpg') }}">
                        <span class="gold-label-fixed">4DX 限定場</span>
                    </a>
                    <a href="/events" class="special-item">
                        <img src="{{ url_for('static', filename='301-300x400.jpg') }}">
                        <span class="gold-label-fixed">特別推介</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="red-divider"></div>

<ul class="sub-category-nav">
    <li><a href="/movies/">Ticketing</a></li>
    <li><a onclick="filterMovies('3d')">3D</a></li>
    <li><a onclick="filterMovies('imax')">IMAX</a></li>
    <li><a onclick="filterMovies('4dx')">4DX</a></li>
    <li><a href="/events">Special</a></li>
    <li><a href="/upcoming">Upcoming</a></li>
    <li><a href="gift_card">Gift Card Shop</a></li>
</ul>

<div class="container" style="margin-top: 30px;">
    <div class="row" id="movie-grid">
        {% for movie in movies %}
        <div class="col-md-3 col-sm-4 col-xs-6 movie-card" 
             data-cat="{{ movie.formats|join(' ') if movie.formats else '' }}" 
             style="text-align: center; margin-bottom: 30px;">
            <a href="{{ url_for('user', username=current_user.username) }}" class="movie-link">
                <img src="{{ movie.poster_url }}" alt="{{ movie.moviename }} poster">
            </a>
            <div style="margin-top: 10px; font-weight: bold;">
                {{ movie.moviename }}
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<script>
    function filterMovies(category) {
        const cards = document.querySelectorAll('.movie-card');
        cards.forEach(card => {
            const categories = card.getAttribute('data-cat').split(' ');
            if (categories.includes(category)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        var carousel = document.getElementById('balancedCarousel');
        var textDisplay = document.getElementById('banner-text');
        
        $(carousel).on('slid.bs.carousel', function () {
            var activeItem = carousel.querySelector('.item.active');
            var title = activeItem.getAttribute('data-title');
            if (title) textDisplay.innerText = title;
        });
    });
</script>
{% endblock %}