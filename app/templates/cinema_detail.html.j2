{% extends "base.html.j2" %}

{% block app_content %}
    <nav class="navbar navbar-default" style="border: none; margin-bottom: 0;">
        <div class="container-fluid"> <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
                <ul class="nav navbar-nav navbar-center" style="display: flex; justify-content: center; float: none;">
                    <li><a href="/movies/">Ticketing</a></li>
                    <li><a href="/upcoming">Upcoming</a></li>
                    <li><a href="/special">Special</a></li>
                    <li><a href="/cinema">Cinema</a></li>
                    <li><a href="#">Gift Card Shop</a></li>
                </ul>
            </div>
        </div>
        <div style="height: 2px; background-color: red; width: 100%;"></div>
    </nav>
<div class="container mt-4">
    <div class="position-relative mb-4">
        <img src="{{ cinema.image_url }}" 
             class="img-fluid rounded" style="width: 100%; height: 300px; object-fit: cover;">
        <h1 class="position-absolute bottom-0 start-0 p-4 text-white" 
            style="text-shadow: 2px 2px 4px #000;">
            {{ cinema.cinemaname }}
        </h1>
    </div>

    <div class="card p-4 mb-4">
        <div class="row">
            <div class="col-md-8">
                <p><strong>Address:</strong> {{ cinema.address }}</p>
            </div>
            <div class="col-md-4 text-md-end">
                <span class="badge bg-secondary">Map</span>
                <span class="badge bg-secondary">Parking</span>
            </div>
        </div>
    </div>

    <div class="card p-4">
        <h4>Schedule</h4>
        <hr>
        
        {% set current_movie = None %}
        
        {% for show in showtimes %}
            {% if show.movie != current_movie %}
                {% set current_movie = show.movie %}
                <div class="mt-4 mb-2">
                    <h5><strong>{{ show.movie.moviename }}</strong></h5>
                </div>
            {% endif %}

            <div class="d-flex align-items-center border-bottom py-2">
                <div class="me-4" style="width: 120px;">
                    {{ show.start_time.strftime('%d/%m (%a)') }}
                </div>
                <div class="me-4" style="width: 100px;">
                    {{ show.start_time.strftime('%H:%M') }}
                </div>
                <div class="me-4 text-muted">
                    {{ show.hall.hallname }}
                </div>
                <div class="ms-auto fw-bold">
                    ${{ show.price_base|int }}
                </div>
            </div>
        {% else %}
            <p class="text-muted">目前沒有場次。</p>
        {% endfor %}
    </div>
</div>
{% endblock %}