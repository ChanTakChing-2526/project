{% extends "base.html.j2" %}

{% block app_content %}
    <style>
        .custom-form-section { border: 1px solid #ddd; padding: 20px; }
        .section-title { border-left: 5px solid #d9534f; padding-left: 10px; margin: 30px 0 20px 0; font-size: 1.2em; }
        .form-group { display: flex; align-items: flex-start; margin-bottom: 20px; }
        .form-group label { width: 200px; padding-top: 5px; font-weight: bold; }
        .field-container { flex: 1; }
        .hint { font-size: 0.85em; color: #666; display: block; margin-top: 5px; }
    </style>

    <div class="custom-form-section">
        <form method="POST">
            {{ form.hidden_tag() }}
            
            <h3 class="section-title">Member Profile</h3>
        
            {% macro render_field(field) %}
            <div class="form-group">
                {{ field.label }}
                <div class="field-container">
                    {{ field(class="form-control", style="max-width: 300px;") }}
                    {% if field.description %}<span class="hint">{{ field.description }}</span>{% endif %}
                </div>
            </div>
            {% endmacro %}

            {{ render_field(form.username) }}
            {{ render_field(form.email) }}
            {{ render_field(form.password) }}
            {{ render_field(form.password2) }}

            <h3 class="section-title">Basic Information</h3>
            {{ render_field(form.given_name) }}
            {{ render_field(form.surname) }}
            
            <div class="form-group">
                {{ form.gender.label }}
                <div class="field-container">{{ form.gender() }}</div>
            </div>
            
            <div class="form-group">
                <label>Birthday</label>
                <div class="field-container" style="display: flex; gap: 10px;">
                    {{ form.day(class="form-control", style="width: auto;") }}
                    {{ form.month(class="form-control", style="width: auto;") }}
                </div>
            </div>

            <div class="form-group">
                {{ form.year.label }}
                <div class="field-container">{{ form.year(class="form-control", style="max-width: 318px;") }}</div>
            </div>

            {{ form.submit(class="btn btn-primary") }}
        </form>
    </div>
{% endblock %}
