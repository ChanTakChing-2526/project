{% extends "base.html.j2" %}

{% block title %}{{ user.username }} 的個人資料{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>{{ user.username }} 的個人資料</h2>
            
            <div class="card mb-4">
                <div class="card-body">
                    <p><strong>Email：</strong> {{ user.email }}</p>
                    <p><strong>積分：</strong> <span class="badge bg-success fs-5">{{ user.points or 0 }} 分</span></p>
                </div>
            </div>

            <h4>我的訂票紀錄</h4>
            
            {% if bookings %}
                <div class="row">
                    {% for booking in bookings %}
                    <div class="col-12 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">{{ booking.showtime.movie.moviename if booking.showtime and booking.showtime.movie else '未知電影' }}</h5>
                                <p class="card-text">
                                    日期：{{ booking.showtime.start_time.strftime('%Y-%m-%d %H:%M') }}<br>
                                    總金額：{{ booking.total_price }} 分<br>
                                    狀態： <span class="badge bg-{{ 'success' if booking.status=='paid' else 'warning' }}">{{ booking.status }}</span>
                                </p>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                <!-- 分頁 -->
                <nav aria-label="Page navigation">
                    <ul class="pagination">
                        {% if prev_url %}
                        <li class="page-item"><a class="page-link" href="{{ prev_url }}">上一頁</a></li>
                        {% endif %}
                        {% if next_url %}
                        <li class="page-item"><a class="page-link" href="{{ next_url }}">下一頁</a></li>
                        {% endif %}
                    </ul>
                </nav>
            {% else %}
                <p class="text-muted">暫時沒有訂票紀錄。</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}