{% extends "base.html.j2" %}
{% block app_content %}
    <style>
    body {
        font-family: 'Open Sans', sans-serif;
        margin: 0;
        color: #333;
        background-color: #ffffff !important;
    }

    .navbar-center {
        display: flex;
        justify-content: center;
        float: none;
    }
    .navbar-nav li a {
        font-weight: bold;
        color: #333 !important;
    }
    .navbar-nav li a:hover {
        color: #ed1c24 !important;
    }
    .navbar-nav li a[href="/gift_card"] {
        color: #ed1c24 !important;
    }
    .red-line-top {
        height: 2px;
        background-color: #ed1c24;
        width: 100%;
    }

    .tabs-row {
        background-color: #f1f1f1;
        display: flex;
        padding-left: 10%;
        border-bottom: 1px solid #ddd;
    }
    .tab-btn {
        padding: 15px 30px;
        cursor: pointer;
        font-weight: bold;
        color: #666;
        border: none;
        background: none;
        font-size: 16px;
    }
    .tab-btn.active {
        background-color: #333;
        color: #fff;
    }

    .box-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 40px;
        border: 1px solid #ddd;
        position: relative;
    }

    .red-v-accent {
        width: 4px;
        height: 25px;
        background-color: #ed1c24;
        position: absolute;
        left: 20px;
        top: 42px;
    }

    .section-title {
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 30px;
        padding-left: 15px;
    }

    .form-group {
        display: flex;
        align-items: center;
        margin-bottom: 20px;
    }
    .form-group label {
        width: 200px;
        font-weight: bold;
        text-align: right;
        margin-right: 20px;
    }
    .form-group input {
        flex: 1;
        max-width: 400px;
        padding: 8px;
        border: 1px solid #ccc;
    }
    .sub-text {
        margin-left: 220px;
        font-size: 12px;
        color: #888;
        margin-top: -15px;
        margin-bottom: 20px;
    }

    .dotted-line {
        border-top: 1px dotted #ccc;
        margin: 20px 0;
    }

    .success-box {
        background-color: #f0fff4;
        border: 1px solid #95e6b7;
        padding: 10px 20px;
        margin-bottom: 20px;
    }
    .success-box p {
        color: #00a854;
        margin: 0;
        font-weight: bold;
    }

    .error-box {
        background-color: #fff1f0;
        border: 1px solid #ffa39e;
        padding: 10px 20px;
        margin-bottom: 20px;
        display: {% if error %}block{% else %}none{% endif %};
    }
    .error-box p {
        color: #ed1c24;
        margin: 0;
        font-weight: bold;
    }

    .btn-row {
        display: flex;
        justify-content: flex-start;
        margin-left: 220px;
        gap: 15px;
        margin-top: 30px;
    }
    .btn-reset {
        background-color: #ccc;
        color: #fff;
        border: none;
        padding: 10px 40px;
        cursor: pointer;
    }
    .btn-submit {
        background-color: #555;
        color: #fff;
        border: none;
        padding: 10px 40px;
        cursor: pointer;
    }

    .footer-note {
        margin-top: 40px;
        background-color: #f9f9f9;
        padding: 15px;
        text-align: center;
        font-size: 13px;
        border-top: 1px solid #eee;
    }
    .footer-note a {
        color: #ed1c24;
        text-decoration: underline;
        cursor: pointer;
    }

    @media (max-width: 768px) {
        .form-group {
            flex-direction: column;
            align-items: flex-start;
        }
        .form-group label {
            width: 100%;
            text-align: left;
            margin-bottom: 5px;
        }
        .sub-text, .btn-row {
            margin-left: 0;
        }
        .tabs-row {
            padding-left: 0;
        }
    }
    </style>
    <div class="tabs-row">
        <button class="tab-btn active" id="tab-check" onclick="switchTab('check')">Check Balance</button>
        <button class="tab-btn" id="tab-setup" onclick="switchTab('setup')">Setup Password</button>
    </div>
    <div class="box-container">
        <div class="red-v-accent"></div>
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                {% for category, message in messages %}
                    {% if category == 'success' %}
                        <div class="success-box">
                            <p>{{ message }}</p>
                        </div>
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endwith %}
        <div id="error-container" class="error-box">
            <p>{{ error or 'Invalid Gift Card Number or Password.' }}</p>
        </div>
        <div id="content-check">
            <div class="section-title">Check Gift Card Balance</div>
            <form method="POST" action="/gift_card">
                <div class="form-group">
                    <label>Gift Card No.</label>
                    <input type="text"
                           name="card_number"
                           required
                           placeholder="Enter 16-digit card number">
                </div>
                <div class="sub-text">(16-digit Number printed in bottom left corner of the card.)</div>
                <div class="dotted-line"></div>
                <div class="form-group">
                    <label>Gift Card Personal Password</label>
                    <input type="password"
                           name="pin"
                           required
                           placeholder="Enter your password"
                           autocomplete="off">
                </div>
                <div class="btn-row">
                    <button type="reset" class="btn-reset">Reset</button>
                    <button type="submit" class="btn-submit">Submit</button>
                </div>
            </form>
        </div>
        <div id="content-setup" style="display:none;">
            <div class="section-title">Setup Password</div>
            <form method="POST" action="/gift_card">
                <div class="form-group">
                    <label>Gift Card No.</label>
                    <input type="text"
                           name="setup_card_number"
                           required
                           placeholder="Enter 16-digit card number">
                </div>
                <div class="sub-text">(16-digit Number printed in bottom left corner of the card.)</div>
                <div class="btn-row">
                    <button type="reset" class="btn-reset">Reset</button>
                    <button type="submit" class="btn-submit">Submit</button>
                </div>
            </form>
        </div>
        <div class="footer-note" id="footer-link-note">
            Gift card holder should <a onclick="switchTab('setup')">set personal password</a> before the first online transaction or balance checking.
        </div>
    </div>
    <script>
    function switchTab(type) {
        const checkBtn = document.getElementById('tab-check');
        const setupBtn = document.getElementById('tab-setup');
        const checkContent = document.getElementById('content-check');
        const setupContent = document.getElementById('content-setup');
        const footerNote = document.getElementById('footer-link-note');

        document.getElementById('error-container').style.display = 'none';

        if (type === 'check') {
            checkBtn.classList.add('active');
            setupBtn.classList.remove('active');
            checkContent.style.display = 'block';
            setupContent.style.display = 'none';
            footerNote.style.display = 'block';
        } else {
            setupBtn.classList.add('active');
            checkBtn.classList.remove('active');
            setupContent.style.display = 'block';
            checkContent.style.display = 'none';
            footerNote.style.display = 'none';
        }
    }

    window.onload = function() {
        {% if error %}
            document.getElementById('error-container').style.display = 'block';
        {% endif %}
    }
    </script>
{% endblock %}
